# MCQA Benchmark - Environment Variables
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM API Keys (Required for model evaluation)
# =============================================================================

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Note: Can use either HF_TOKEN or HUGGINGFACE_TOKEN
HF_TOKEN=
HUGGINGFACE_TOKEN=

# =============================================================================
# Web Search API Keys (Required for contamination detection)
# =============================================================================
# At least one search engine API key is required if using contamination metric with web search functionality

# Google Custom Search API; Get key at: https://developers.google.com/custom-search/v1/overview
GOOGLE_SEARCH_API_KEY=
GOOGLE_CSE_ID=

# Brave Search API Key; Get key at: https://brave.com/search/api/
BRAVE_API_KEY=

# Tavily API Key; Get key at: https://tavily.com/
TAVILY_API_KEY=

# Serper API Key; Get key at: https://serper.dev/
SERPER_API_KEY=

# Exa API Key; Get key at: https://exa.ai/
EXA_API_KEY=

# Optional: Perplexity API Key
# Perplexity API key is handled through litellm configuration so configure through its settings